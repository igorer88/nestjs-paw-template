{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc"
  ],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-unnecessary-parameter-property-assignment": "off",
    "no-unused-vars": "warn",
    "no-var-requires": "error",
    "no-explicit-any": "error",
    "ban-ts-comment": "off",
    "no-else-return": "error",
    "no-thenable": "off"
  },
  "env": {
    "builtin": true,
    "node": true,
    "jest": true
  },
  "ignorePatterns": ["dist/*", "node_modules/*", "coverage/*", "build/*", "lib/*", "docs/*"]
}
