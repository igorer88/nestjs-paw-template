{
  "name": "nestjs-paw-template",
  "version": "0.1.0",
  "description": "NestJs base template with TypeORM, PostgreSQL, SQLite, Swagger, E2E tests, and more.",
  "author": "Igor Escalona",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=24.x",
    "pnpm": ">=10.x"
  },
  "keywords": [
    "typescript",
    "nestjs",
    "template"
  ],
  "scripts": {
    "setup:agents": "node ./config/scripts/sync-agents.mjs",
    "generate:secret": "node ./config/scripts/generate-secret-key.mjs",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "rimraf coverage && jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "orm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli -d src/orm.config.ts",
    "migration:generate": "pnpm orm migration:generate",
    "migration:run": "pnpm orm migration:run",
    "migration:revert": "pnpm orm migration:revert",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "pnpm lint",
      "pnpm format",
      "pnpm test -- --passWithNoTests"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@nestjs-mcp/server": "^1.0.0",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/mapped-types": "2.1.0",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "cache-manager": "^7.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "helmet": "^8.1.0",
    "http-method-enum": "^1.0.0",
    "joi": "^18.0.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sqlite3": "^6.0.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/compat": "^2.0.3",
    "@helljs/eslint-import-resolver-x": "^1.1.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.16",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.18",
    "@types/express": "^5.0.6",
    "@types/hapi__joi": "^17.1.15",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "commitlint": "^20.5.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-oxc": "^0.15.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "yaml": "^2.8.2"
  },
  "pnpm": {
    "overrides": {
      "ajv-formats": "^2.1.1",
      "file-type": ">=21.3.2",
      "tar": ">=7.5.8",
      "minimatch": ">=10.2.3"
    }
  }
}
