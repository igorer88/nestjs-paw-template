# =============================================================================
# DEVELOPMENT ONLY - Do not use in production!
# Generate your own secrets for each environment.
# =============================================================================

# Environment
NODE_ENV=development

# Docker build stage
BUILD_STAGE=dev

# API Port
API_PORT=3000

# API Log levels
API_LOGGER_LEVELS=log,error,warn,debug,verbose,fatal

# Secret Key - REPLACE with a strong key in production!
# Generate with: pnpm generate:secret
API_SECRET_KEY=your-secret-key-here

# API Allowed Origins (comma-separated list)
# In production, this is REQUIRED and must be set explicitly
ALLOWED_ORIGINS=http://localhost:3000

# Cache Configuration
# CACHE_DRIVER=memory  # 'memory' (default) or 'redis'
# CACHE_TTL=60000     # Time-to-live in ms (default: 1 minute)
# CACHE_MAX_SIZE=5000 # Max entries for memory cache (LRU)
# REDIS_URL=redis://localhost:6379  # For redis driver

# Rate Limiting (THROTTLE_TTL = time-to-live in ms, THROTTLE_LIMIT = max requests per TTL)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# IP Logging - Options: enabled, disabled, anonymized (default)
# Use 'enabled' for full IP logging, 'anonymized' for privacy-safe logging
IP_LOG_LEVEL=anonymized

# Database (SQLite for local development, do not use in Production!)
DB_DRIVER=sqlite
DB_SQLITE_PATH=config/db/db.sqlite3

# For PostgreSQL (uncomment and configure for production):
# DB_DRIVER=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=your-db-name
# DB_USER=postgres
# DB_PASSWORD=your-strong-password

# PG Admin credentials (development only)
# PGADMIN_DEFAULT_EMAIL=youremail@example.com
# PGADMIN_DEFAULT_PASSWORD=yourpassword
# PGADMIN_PORT=5050
